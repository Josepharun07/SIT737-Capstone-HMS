{
  "name": "blueberry-hms",
  "version": "1.0.0",
  "private": true,
  "description": "Blueberry Hotel Management Suite",
  "scripts": {
    "dev": "concurrently -n \"API,ADMIN\" -c \"blue,green\" \"pnpm run dev:api\" \"pnpm run dev:admin\"",
    "dev:api": "pnpm --filter @blueberry/api-core run dev",
    "dev:admin": "pnpm --filter admin-panel run dev",
    "build": "pnpm --filter @blueberry/api-core run build && pnpm --filter admin-panel run build",
    "start": "pnpm --filter @blueberry/api-core run start:prod",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:restart": "docker-compose restart",
    "clean": "rm -rf node_modules apps/*/node_modules apps/*/dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.33.2"
}
