FROM node:18-alpine
WORKDIR /app
# Install pnpm
RUN npm install -g pnpm
# Copy workspace config and source code
COPY . .
# Install dependencies and build the API
RUN pnpm install
RUN pnpm run build --filter api-core
# Expose API port
EXPOSE 4000
# Start the API
CMD ["pnpm", "run", "start:api"]